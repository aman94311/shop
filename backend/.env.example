# ============================================================
#  ABHI SANITARY AND HARDWARE — Backend Environment Variables
#  Copy this file to .env and fill in your actual values
# ============================================================

# Server port
PORT=5000

# MongoDB connection string
# Local:  mongodb://localhost:27017/abhi_shop
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/abhi_shop
MONGO_URI=your_mongodb_connection_string_here

# Shop owner WhatsApp number (digits only, with country code, NO + sign)
# Example: 919876543210
WHATSAPP_NUMBER=your_whatsapp_number_here

# Frontend origin for CORS (change in production)
FRONTEND_URL=http://localhost:5173

# SMTP Email Configuration (Gmail App Password, Brevo, Ethereal, etc.)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user_email
SMTP_PASS=your_smtp_password
SMTP_FROM=your_sender_email
